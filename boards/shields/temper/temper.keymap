#include <dt-bindings/zmk/behaviors.h>
#include <behaviors/num_word.dtsi>
#include <behaviors/num_word.dtsi>
#include <input/processors.dtsi>
#include "keys_it.h"

#define ZMK_POINTING_DEFAULT_MOVE_VAL 1500
#define ZMK_POINTING_DEFAULT_SCRL_VAL 40

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/pointing.h>

&num_word { continue-list = <LPAR RPAR IT_EQUAL SLASH MINUS ASTRK PLUS PRCNT COMMA DOT>; };

&caps_word { continue-list = <SPACE>; };

&mt {
    tapping-term-ms = <130>; // This is the value already set by default
};

/ {
    macros {
        Passpc: Passpc {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp N0 &kp N3 &kp N1 &kp N1>;
        };

        Passfirma: Passfirma {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp N7 &kp N3 &kp N0 &kp N0 &kp N2 &kp N0 &kp N9 &kp N9>;
        };
    };
};

/ {
    play_y: play_y {
        compatible = "zmk,behavior-tap-dance";
        label = "PLAY_Y";
        #binding-cells = <0>;
        bindings = <&kp Y>, <&kp C_PLAY_PAUSE>;
    };

    nav_word: nav_word {
        compatible = "zmk,behavior-auto-layer";
        #binding-cells = <1>;
        continue-list = <LEFT_ALT LEFT_GUI LEFT_CONTROL LEFT_SHIFT LEFT_ARROW UP_ARROW RIGHT_ARROW DOWN_ARROW>;
        ignore-modifiers;
    };

    mau_word: mau_word {
        compatible = "zmk,behavior-auto-layer";
        #binding-cells = <1>;
        continue-list = <MB2 MB3 MB1 MOVE_LEFT MOVE_UP MOVE_RIGHT MOVE_DOWN SCRL_UP SCRL_DOWN SCRL_RIGHT SCRL_LEFT DEL ESC SPACE ENTER>;
        ignore-modifiers;
    };
};

/ {
    combos {
        compatible = "zmk,combos";

        combo_backspace {
            timeout-ms = <50>;
            key-positions = <16 17>;
            bindings = <&kp BSPC>;
        };

        combo_space {
            timeout-ms = <60>;
            key-positions = <12 13>;
            bindings = <&kp SPACE>;
        };

        combo_enter {
            timeout-ms = <50>;
            key-positions = <26 27>;
            bindings = <&kp ENTER>;
        };

        del {
            bindings = <&kp DEL>;
            key-positions = <22 23>;
        };

        num {
            bindings = <&num_word 2>;
            key-positions = <1 11>;
        };

        esc {
            bindings = <&kp ESCAPE>;
            key-positions = <4 14>;
        };

        tab2 {
            bindings = <&kp TAB>;
            key-positions = <14 24>;
        };

        naviga {
            bindings = <&nav_word 1>;
            key-positions = <11 21>;
        };

        apos {
            bindings = <&kp APOS>;
            key-positions = <16 26>;
        };

        grave {
            bindings = <&kp GRAVE>;
            key-positions = <17 27>;
        };
    };
};

/ {
    behaviors {
    };

    keymap {
        compatible = "zmk,keymap";

        Base {
            display-name = "QWERTY";
            bindings = <
&kp Q  &kp W  &kp E  &kp R  &kp T      &play_y  &kp U  &kp I  &kp O  &sk LEFT_ALT
&kp A  &kp S  &kp D  &kp F  &kp G      &kp H  &kp J  &kp K  &kp L  &kp P  
&kp Z  &kp X  &kp C  &kp V  &kp B      &kp N  &kp M  &kp COMMA  &kp KP_DOT  &sk LEFT_GUI  
     &mau_word 4  &sk LEFT_CONTROL     &sk LEFT_SHIFT  &sl 3  &caps_word  &to 0
            >;
        };

        FRECCE {
            display-name = "OPZIONI";
            bindings = <
&trans  &trans  &trans  &trans  &trans                                    &trans  &trans  &trans  &trans  &trans  
&sk LEFT_ALT  &sk LEFT_GUI  &sk LEFT_CONTROL  &sk LEFT_SHIFT  &trans      &trans  &kp LEFT_ARROW  &kp UP_ARROW  &kp RIGHT_ARROW  &trans  
&trans  &trans  &trans  &trans  &trans                                    &trans  &trans  &kp DOWN_ARROW  &trans  &trans   
&trans  &trans  &trans                                                    &trans  &trans  &tran
            >;
        };

        NUMBER {
            display-name = "NUMERI";
            bindings = <
&trans  &kp KP_N7  &kp KP_N8  &kp KP_N9  &mt ASTRK SLASH     &trans  &trans  &trans  &trans  &trans  
&trans  &kp KP_N4  &kp KP_N5  &kp KP_N6  &mt PLUS MINUS      &trans  &trans  &trans  &trans  &trans  
&trans  &kp KP_N1  &kp KP_N2  &kp KP_N3  &mt EQUAL ENTER     &trans  &trans  &trans  &trans  &trans  
&kp BSPC  &kp COMMA   &kp KP_N0                              &trans  &trans  &trans
            >;
        };

        SIMBOLI {
            display-name = "SIMBOLI";
            bindings = <
&mt POUND AMPS  &mt GT LT  &mt BSLH DOLLAR  &mt LBKT RBKT  &mt LBRC RBRC       &kp SEMI  &kp COLON  &kp EXCL  &kp QUESTION  &Passpc
&kp F1  &kp F2  &kp F3  &kp F4  &kp F5                                         &kp DQT  &kp LPAR  &kp RPAR  &kp UNDER  &Passfirma  
&kp F6  &kp F7  &kp F8  &kp F9  &kp F10                                        &kp SLASH  &kp AT  &kp HOME  &kp PERCENT  &kp PRINTSCREEN
&trans  &trans  &trans                                                         &trans  &trans  &trans
            >;
        };

        MOUSE {
            display-name = "MOUSE";
            bindings = <
&trans  &kp DEL  &kp ESC  &msc SCRL_UP  &trans                              &trans  &trans  &trans  &trans  &trans  
&trans  &msc SCRL_LEFT  &mkp MB2  &mkp MB3  &mkp MB1  &msc SCRL_RIGHT       &trans  &mmv MOVE_LEFT  &mmv MOVE_UP  &mmv MOVE_RIGHT  &trans  
&trans  &kp ENTER  &kp SPACE  &msc SCRL_DOWN  &trans                        &trans  &trans  &mmv MOVE_DOWN  &trans  &trans  
&trans  &trans  &trans                                                      &trans  &trans  &trans
            >;
        };
    };
};
                };

        };
};
